; WinUSB para Samsung modo Download/Odin — VID 04E8 PID 685D
; Uso: Administrador de dispositivos → actualizar controlador → buscar en esta carpeta
; Nota: en dispositivos compuestos puede hacer falta instalar en la interfaz MI correcta.
; Zadig suele ser más simple: https://zadig.akeo.ie/

[Version]
Signature   = "$Windows NT$"
Class       = USBDevice
ClassGUID   = {88BAE032-5A81-49f0-BC3D-A4FF138216D6}
Provider    = %ManufacturerName%
DriverVer   = 05/21/2026,1.0.0.0
CatalogFile = samsung_odin_winusb.cat

[Manufacturer]
%ManufacturerName% = SamsungOdin, NTamd64

; Varias interfaces compuestas (MI). Instala en la que sea CDC Data / bulk Odin.
[SamsungOdin.NTamd64]
%Samsung.Odin.MI0% = USB_Install, USB\VID_04E8&PID_685D&MI_00
%Samsung.Odin.MI1% = USB_Install, USB\VID_04E8&PID_685D&MI_01
%Samsung.Odin.MI2% = USB_Install, USB\VID_04E8&PID_685D&MI_02
%Samsung.Odin.MI3% = USB_Install, USB\VID_04E8&PID_685D&MI_03

[USB_Install]
Include = winusb.inf
Needs   = WINUSB.NT

[USB_Install.Services]
Include = winusb.inf
Needs   = WINUSB.NT.Services

[USB_Install.HW]
AddReg = Dev_AddReg

[Dev_AddReg]
HKR,,DeviceInterfaceGUIDs,0x10000,"{88BAE032-5A81-49f0-BC3D-A4FF138216D6}"

[Strings]
ManufacturerName = "OdinThorFlash"
Samsung.Odin.MI0   = "Samsung Odin Download (04E8:685D) Interface 0"
Samsung.Odin.MI1   = "Samsung Odin Download (04E8:685D) Interface 1"
Samsung.Odin.MI2   = "Samsung Odin Download (04E8:685D) Interface 2"
Samsung.Odin.MI3   = "Samsung Odin Download (04E8:685D) Interface 3"
